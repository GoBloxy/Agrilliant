<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import com.gluonhq.charm.glisten.control.CharmListView?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.LogsController"
      spacing="16" styleClass="content-pane">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Activity Logs" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnExport" text="Export CSV" styleClass="btn-primary" onAction="#onExport">
            <graphic><FontIcon iconLiteral="fth-download" iconSize="14"/></graphic>
        </Button>
        <Button fx:id="btnClear" text="Clear Logs" styleClass="btn-danger" onAction="#onClear"/>
    </HBox>

    <!--
      Summary cards: FlowPane wraps to 1 / 2 / 4 columns depending on width.
      Card minWidth=200 forces a wrap when (200*N + hgap*(N-1)) > available.
        Phone (≤460dp):  1 column × 4
        Tablet (~860dp): 2 columns × 2
        Desktop ≥860dp:  4 columns × 1
    -->
    <FlowPane hgap="16" vgap="16" prefWrapLength="200">
        <VBox styleClass="card" minWidth="200" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-primary" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-file-text" iconSize="18" iconColor="#2e7d32"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total Logs" styleClass="summary-card-title"/>
                    <Label fx:id="lblTotal" text="0" styleClass="summary-card-value"/>
                    <Label text="All system events" styleClass="summary-card-subtitle"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-info" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-info" iconSize="18" iconColor="#1d4ed8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Info" styleClass="summary-card-title"/>
                    <Label fx:id="lblInfo" text="0" styleClass="summary-card-value"/>
                    <Label text="Informational messages" styleClass="summary-card-subtitle"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-warning" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-alert-triangle" iconSize="18" iconColor="#d97706"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Warnings" styleClass="summary-card-title"/>
                    <Label fx:id="lblWarnings" text="0" styleClass="summary-card-value"/>
                    <Label text="Potential issues" styleClass="summary-card-subtitle"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-error" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-x-circle" iconSize="18" iconColor="#dc2626"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Errors" styleClass="summary-card-title"/>
                    <Label fx:id="lblErrors" text="0" styleClass="summary-card-value"/>
                    <Label text="Critical failures" styleClass="summary-card-subtitle"/>
                </VBox>
            </HBox>
        </VBox>
    </FlowPane>

    <!-- Filter row: FlowPane wraps search box + combos onto multiple rows on narrow screens. -->
    <FlowPane hgap="12" vgap="12">
        <HBox alignment="CENTER_LEFT" styleClass="search-box" minWidth="240" HBox.hgrow="NEVER">
            <padding><Insets right="8" left="8"/></padding>
            <FontIcon iconLiteral="fth-search" iconSize="14" styleClass="search-icon"/>
            <TextField fx:id="txtSearch" promptText="Search logs..." styleClass="search-field"/>
        </HBox>
        <ComboBox fx:id="cmbType" promptText="All Types" styleClass="filter-combo"/>
        <DatePicker fx:id="dpFrom" promptText="From" styleClass="filter-combo"/>
        <DatePicker fx:id="dpTo" promptText="To" styleClass="filter-combo"/>
    </FlowPane>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="System Logs" styleClass="card-title"/>
        <CharmListView fx:id="logList" VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>