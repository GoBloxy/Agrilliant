<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.DashboardController"
      styleClass="dashboard-root">

    <!--
      ═══════════════ LEFT SIDEBAR (LEGACY — hidden on mobile) ═══════════════

      The sidebar is now visible="false" managed="false" by default. On mobile,
      ShellView replaces it with a Gluon NavigationDrawer (slides in from the
      AppBar's hamburger). The sidebar's onAction handlers all route through
      DashboardController.navigate(NavTarget) so both nav surfaces share a
      single dispatch path — re-enabling the sidebar via mobile.css media-query
      equivalent is a one-line change.
    -->
        <VBox fx:id="sidebar" prefWidth="240" minWidth="240" maxWidth="240" spacing="3" styleClass="sidebar" visible="false" managed="false">
            <padding><Insets top="20" right="15" bottom="15" left="15"/></padding>

            <!-- Logo + App Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitWidth="36" fitHeight="36" preserveRatio="true" smooth="true">
                    <image><Image url="@../images/logo.png"/></image>
                </ImageView>
                <VBox spacing="0">
                    <Label text="Agrilliant" styleClass="sidebar-title"/>
                    <Label text="Smart Farm System" styleClass="sidebar-subtitle"/>
                </VBox>
            </HBox>

            <Region prefHeight="15"/>

            <!-- Navigation -->
            <Button fx:id="btnDashboard"  onAction="#onNavDashboard"  styleClass="nav-btn,nav-active" maxWidth="Infinity" text="Dashboard"  graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-grid" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnMonitoring" onAction="#onNavMonitoring" styleClass="nav-btn" maxWidth="Infinity" text="Monitoring" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-activity" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnDisease"    onAction="#onNavDisease"    styleClass="nav-btn" maxWidth="Infinity" text="Disease Detection" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-search" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnAlerts"     onAction="#onNavAlerts"     styleClass="nav-btn" maxWidth="Infinity" text="Alerts"     graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-bell" iconSize="16"/></graphic>
            </Button>

            <!-- Crops & Plots (expandable) -->
            <Button fx:id="btnCrops" onAction="#toggleCropsSubmenu" styleClass="nav-btn" maxWidth="Infinity" text="Crops &amp; Plots" graphicTextGap="12" contentDisplay="LEFT">
                <graphic><FontIcon iconLiteral="fth-map" iconSize="16"/></graphic>
            </Button>
            <VBox fx:id="cropsSubmenu" spacing="2" managed="false" visible="false">
                <Button fx:id="btnCropsCrops" onAction="#onNavCropsList" styleClass="nav-btn,nav-sub" maxWidth="Infinity" text="Crops" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fth-circle" iconSize="6"/></graphic>
                </Button>
                <Button fx:id="btnCropsPlots" onAction="#onNavPlotsList" styleClass="nav-btn,nav-sub" maxWidth="Infinity" text="Plots" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fth-circle" iconSize="6"/></graphic>
                </Button>
            </VBox>

            <Button fx:id="btnWorkers"    onAction="#onNavWorkers"    styleClass="nav-btn" maxWidth="Infinity" text="Workers"    graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-users" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnAttendance" onAction="#onNavAttendance" styleClass="nav-btn" maxWidth="Infinity" text="Attendance" graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-user-check" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnTasks"      onAction="#onNavTasks"     styleClass="nav-btn" maxWidth="Infinity" text="Tasks"      graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-check-square" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnHarvests"   onAction="#onNavHarvests"  styleClass="nav-btn" maxWidth="Infinity" text="Harvests"   graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-package" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnReports"    onAction="#onNavReports"   styleClass="nav-btn" maxWidth="Infinity" text="Reports"    graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-bar-chart-2" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnSettings"   onAction="#onNavSettings"  styleClass="nav-btn" maxWidth="Infinity" text="Settings"   graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-settings" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnUsers"      onAction="#onNavUsers"     styleClass="nav-btn" maxWidth="Infinity" text="Users"      graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-user" iconSize="16"/></graphic>
            </Button>
            <Button fx:id="btnLogs"       onAction="#onNavLogs"      styleClass="nav-btn" maxWidth="Infinity" text="Logs"       graphicTextGap="12">
                <graphic><FontIcon iconLiteral="fth-file-text" iconSize="16"/></graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Status Card -->
            <VBox spacing="6" styleClass="status-card">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Circle fx:id="dotSystem" radius="4" styleClass="status-dot-online"/>
                    <VBox spacing="0">
                        <Label text="System Status" styleClass="sidebar-status-title"/>
                        <Label fx:id="lblSystemStatus" text="Online" styleClass="sidebar-status-value"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Circle fx:id="dotDb" radius="4" styleClass="status-dot-online"/>
                    <VBox spacing="0">
                        <Label text="Database" styleClass="sidebar-status-title"/>
                        <Label fx:id="lblDbStatus" text="Connected" styleClass="sidebar-status-value"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Circle fx:id="dotSensors" radius="4" styleClass="status-dot-online"/>
                    <VBox spacing="0">
                        <Label text="IoT Sensors" styleClass="sidebar-status-title"/>
                        <Label fx:id="lblSensorStatus" text="0 Active" styleClass="sidebar-status-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <Label text="Version 1.0.0" styleClass="sidebar-version" maxWidth="Infinity" alignment="CENTER"/>
        </VBox>

    <!-- ═══════════════ MAIN CONTENT AREA (top bar + scrollable content) ═══════════════ -->
    <VBox HBox.hgrow="ALWAYS" styleClass="content-area">

        <!-- ═══════════════ TOP BAR (LEGACY — hidden on mobile) ═══════════════
             Replaced by the Gluon AppBar that ShellView re-enables. The hidden
             labels (lblDate, lblTime, lblTempTop, lblUserName, lblUserRole)
             still get updated by DashboardController so the data is ready
             if the topbar is re-shown via a future width-based toggle. -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar" visible="false" managed="false">
            <padding><Insets top="12" right="25" bottom="12" left="25"/></padding>
            <FontIcon iconLiteral="fth-menu" iconSize="20"/>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Weather -->
            <HBox alignment="CENTER" spacing="8">
                <FontIcon iconLiteral="fth-cloud" iconSize="22" styleClass="weather-icon"/>
                <VBox spacing="0">
                    <Label fx:id="lblTempTop" text="28°C" styleClass="topbar-strong"/>
                    <Label text="Partly Cloudy" styleClass="topbar-muted"/>
                </VBox>
            </HBox>

            <!-- Date/Time -->
            <VBox spacing="0" alignment="CENTER_RIGHT">
                <Label fx:id="lblDate" text="May 21, 2025" styleClass="topbar-strong"/>
                <Label fx:id="lblTime" text="10:30:45 AM" styleClass="topbar-muted"/>
            </VBox>

            <!-- User Pill (clickable for dropdown) -->
            <HBox fx:id="userPill" alignment="CENTER" spacing="10" styleClass="user-pill" onMouseClicked="#showUserMenu">
                <padding><Insets top="4" right="10" bottom="4" left="4"/></padding>
                <StackPane styleClass="avatar-circle" prefWidth="32" prefHeight="32">
                    <FontIcon iconLiteral="fth-user" iconSize="16"/>
                </StackPane>
                <VBox spacing="0">
                    <Label fx:id="lblUserName" text="John Farmer" styleClass="topbar-strong"/>
                    <Label fx:id="lblUserRole" text="Farm Owner" styleClass="topbar-muted"/>
                </VBox>
                <FontIcon iconLiteral="fth-chevron-down" iconSize="14"/>
            </HBox>
        </HBox>

        <!-- ═══════════════ SCROLLABLE PAGE CONTAINER ═══════════════ -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="page-scroll">
            <StackPane fx:id="pageContainer">
                <VBox fx:id="dashboardPage" spacing="12" styleClass="content-pane">
                    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                    <VBox styleClass="page-header">
                        <Label text="Farm home" styleClass="page-kicker"/>
                        <Label text="Dashboard" styleClass="page-title"/>
                        <Label text="Live field health, work, and harvest signals" styleClass="page-subtitle" wrapText="true"/>
                    </VBox>

            <!-- ─────────── SENSORS (full-width, stacked vertically) ─────────── -->
            <VBox styleClass="hero-card" spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Live Environmental Monitor" styleClass="hero-title"/>
                        <Label text="Current conditions across connected plots" styleClass="hero-subtitle" wrapText="true"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewSensors" text="View All"/>
                </HBox>
                <!-- Sensor cards stacked vertically on mobile -->
                <VBox spacing="8">
                    <!-- Temperature Card -->
                    <HBox styleClass="sensor-card" spacing="10" alignment="CENTER_LEFT">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <FontIcon iconLiteral="fth-thermometer" iconSize="18" styleClass="sensor-icon-temp"/>
                        <VBox spacing="0" HBox.hgrow="ALWAYS">
                            <Label text="Temperature" styleClass="sensor-label"/>
                            <Label fx:id="lblTemperature" text="--.- °C" styleClass="sensor-value"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <Label fx:id="lblTempPlot" text="Plot — North Field" styleClass="sensor-plot"/>
                            <Label fx:id="lblTempStatus" text="Normal" styleClass="badge,badge-normal"/>
                        </VBox>
                    </HBox>

                    <!-- Humidity Card -->
                    <HBox styleClass="sensor-card" spacing="10" alignment="CENTER_LEFT">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <FontIcon iconLiteral="fth-droplet" iconSize="18" styleClass="sensor-icon-hum"/>
                        <VBox spacing="0" HBox.hgrow="ALWAYS">
                            <Label text="Humidity" styleClass="sensor-label"/>
                            <Label fx:id="lblHumidity" text="-- %" styleClass="sensor-value"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <Label fx:id="lblHumPlot" text="Plot — North Field" styleClass="sensor-plot"/>
                            <Label fx:id="lblHumStatus" text="Normal" styleClass="badge,badge-normal"/>
                        </VBox>
                    </HBox>

                    <!-- Soil Moisture Card -->
                    <HBox styleClass="sensor-card" spacing="10" alignment="CENTER_LEFT">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <FontIcon iconLiteral="fth-droplet" iconSize="18" styleClass="sensor-icon-soil"/>
                        <VBox spacing="0" HBox.hgrow="ALWAYS">
                            <Label text="Soil Moisture" styleClass="sensor-label"/>
                            <Label fx:id="lblSoilMoisture" text="-- %" styleClass="sensor-value"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER_RIGHT">
                            <Label fx:id="lblSoilPlot" text="Plot — North Field" styleClass="sensor-plot"/>
                            <Label fx:id="lblSoilStatus" text="Normal" styleClass="badge,badge-normal"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- ─────────── CHART (full-width) ─────────── -->
            <VBox styleClass="chart-card">
                <Label text="Temperature &amp; Humidity Trend" styleClass="card-title"/>
                <StackPane fx:id="chartContainer" prefHeight="180" maxHeight="180"/>
            </VBox>

            <!-- ─────────── FIELD OVERVIEW (full-width) ─────────── -->
            <VBox styleClass="section-card">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Field Overview" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkManagePlots" text="Manage Plots"/>
                </HBox>

                <!-- Field Map (visual representation of plots) -->
                <Pane fx:id="fieldMap" styleClass="field-map" prefHeight="200" minHeight="200">
                    <Rectangle layoutX="20"  layoutY="20"  width="80"  height="50"  styleClass="plot-normal"/>
                    <Label    layoutX="40"  layoutY="35"  text="Plot 1" styleClass="plot-label"/>

                    <Rectangle layoutX="120" layoutY="20"  width="90"  height="60"  styleClass="plot-warning"/>
                    <Label    layoutX="145" layoutY="40"  text="Plot 2" styleClass="plot-label"/>

                    <Rectangle layoutX="20"  layoutY="85"  width="80"  height="60"  styleClass="plot-critical"/>
                    <Label    layoutX="40"  layoutY="105" text="Plot 3" styleClass="plot-label"/>

                    <Rectangle layoutX="120" layoutY="95"  width="90"  height="50"  styleClass="plot-normal"/>
                    <Label    layoutX="145" layoutY="110" text="Plot 4" styleClass="plot-label"/>

                    <Rectangle layoutX="40"  layoutY="155" width="140" height="40"  styleClass="plot-normal"/>
                    <Label    layoutX="85"  layoutY="165" text="Plot 5" styleClass="plot-label"/>
                </Pane>

                <!-- Legend -->
                <HBox spacing="10" alignment="CENTER" styleClass="map-legend">
                    <padding><Insets top="8" right="0" bottom="0" left="0"/></padding>
                    <HBox alignment="CENTER" spacing="4"><Circle radius="4" styleClass="legend-normal"/>  <Label text="Normal"   styleClass="legend-text"/></HBox>
                    <HBox alignment="CENTER" spacing="4"><Circle radius="4" styleClass="legend-warning"/> <Label text="Warning"  styleClass="legend-text"/></HBox>
                    <HBox alignment="CENTER" spacing="4"><Circle radius="4" styleClass="legend-critical"/><Label text="Critical" styleClass="legend-text"/></HBox>
                    <HBox alignment="CENTER" spacing="4"><Circle radius="4" styleClass="legend-offline"/> <Label text="Offline"  styleClass="legend-text"/></HBox>
                </HBox>
            </VBox>

            <!-- ─────────── RECENT ALERTS (full-width) ─────────── -->
            <VBox styleClass="section-card" spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Recent Alerts" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewAlerts" text="View All"/>
                </HBox>
                <ListView fx:id="alertListView" prefHeight="150" maxHeight="150" styleClass="ghost-list"/>
                <Hyperlink fx:id="linkShowAllAlerts" text="Show all alerts →" styleClass="link-end"/>
            </VBox>

            <!-- ─────────── TASKS (full-width) ─────────── -->
            <VBox styleClass="section-card" spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblTasksTitle" text="Tasks" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewTasks" text="View All"/>
                </HBox>
                <ListView fx:id="taskListView" prefHeight="140" maxHeight="140" styleClass="ghost-list"/>
                <Hyperlink fx:id="linkViewAllTasks" text="View all tasks →" styleClass="link-end"/>
            </VBox>

            <!-- ─────────── CROP OVERVIEW (full-width) ─────────── -->
            <VBox styleClass="list-card">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Crop &amp; Plot Overview" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewCrops" text="View All"/>
                </HBox>
                <TableView fx:id="cropTable" prefHeight="160">
                    <columns>
                        <TableColumn fx:id="colCropName"     text="Crop"          prefWidth="90"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colCropPlot"     text="Plot"          prefWidth="90"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colCropStage"    text="Stage"         prefWidth="80"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colPlantingDate" text="Planted"       prefWidth="80"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colCropStatus"   text="Status"        prefWidth="70"  reorderable="false" resizable="true"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ─────────── WORKER OVERVIEW (full-width) ─────────── -->
            <VBox styleClass="list-card">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Worker Overview" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewWorkers" text="View All"/>
                </HBox>
                <TableView fx:id="workerTable" prefHeight="160">
                    <columns>
                        <TableColumn fx:id="colWorkerName"    text="Worker"       prefWidth="90"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colWorkerRole"    text="Role"         prefWidth="80"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colWorkerStatus"  text="Status"       prefWidth="70"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colWorkerTask"    text="Task"         prefWidth="90"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colWorkload"      text="Workload"     prefWidth="70"  reorderable="false" resizable="true"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ─────────── QUICK ACTIONS (full-width, 2-column grid) ─────────── -->
            <VBox styleClass="section-card" spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="Quick Actions" styleClass="card-title"/>
                <GridPane hgap="8" vgap="8" VBox.vgrow="ALWAYS">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>
                    <Button fx:id="btnAddCrop"      onAction="#onAddCrop"      text="Add Crop"      styleClass="action-btn,btn-tonal" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="0" graphicTextGap="6">
                        <graphic><FontIcon iconLiteral="fth-plus-circle" iconSize="16"/></graphic>
                    </Button>
                    <Button fx:id="btnAddTask"      onAction="#onAddTask"      text="Add Task"      styleClass="action-btn,btn-tonal" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0" graphicTextGap="6">
                        <graphic><FontIcon iconLiteral="fth-clipboard" iconSize="16"/></graphic>
                    </Button>
                    <Button fx:id="btnLogHarvest"   onAction="#onLogHarvest"   text="Log Harvest"   styleClass="action-btn,btn-tonal" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1" graphicTextGap="6">
                        <graphic><FontIcon iconLiteral="fth-package" iconSize="16"/></graphic>
                    </Button>
                    <Button fx:id="btnExportReport" onAction="#onExportReport" text="Export Report" styleClass="action-btn,btn-tonal" maxWidth="Infinity" maxHeight="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" graphicTextGap="6">
                        <graphic><FontIcon iconLiteral="fth-file-text" iconSize="16"/></graphic>
                    </Button>
                </GridPane>
            </VBox>

            <!-- ─────────── RECENT HARVESTS (full-width) ─────────── -->
            <VBox styleClass="list-card">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Recent Harvests" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink fx:id="linkViewHarvests" text="View All"/>
                </HBox>
                <TableView fx:id="harvestTable" prefHeight="150">
                    <columns>
                        <TableColumn fx:id="colHarvestCrop"     text="Crop"           prefWidth="70"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestPlot"     text="Plot"           prefWidth="70"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestDate"     text="Date"           prefWidth="80"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestQty"      text="Qty (kg)"       prefWidth="70"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestGrade"    text="Grade"          prefWidth="60"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestExpected" text="Expected"       prefWidth="70"  reorderable="false" resizable="true"/>
                        <TableColumn fx:id="colHarvestPerf"     text="Perf"           prefWidth="60"  reorderable="false" resizable="true"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ─────────── REPORTS EXPORT (full-width) ─────────── -->
            <VBox styleClass="card" spacing="6">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="Reports Export" styleClass="card-title"/>
                <Button fx:id="btnExportSensorCSV"  onAction="#onExportSensorCSV"  text="Sensor Logs (CSV)"     maxWidth="Infinity" styleClass="export-btn,btn-tonal" alignment="CENTER_LEFT" contentDisplay="RIGHT" graphicTextGap="0">
                    <graphic><FontIcon iconLiteral="fth-download" iconSize="14"/></graphic>
                </Button>
                <Button fx:id="btnExportHarvestCSV" onAction="#onExportHarvestCSV" text="Harvest Summary (CSV)" maxWidth="Infinity" styleClass="export-btn,btn-tonal" alignment="CENTER_LEFT" contentDisplay="RIGHT" graphicTextGap="0">
                    <graphic><FontIcon iconLiteral="fth-download" iconSize="14"/></graphic>
                </Button>
                <Button fx:id="btnExportAlertCSV"   onAction="#onExportAlertCSV"   text="Alert History (CSV)"   maxWidth="Infinity" styleClass="export-btn,btn-tonal" alignment="CENTER_LEFT" contentDisplay="RIGHT" graphicTextGap="0">
                    <graphic><FontIcon iconLiteral="fth-download" iconSize="14"/></graphic>
                </Button>
            </VBox>
                </VBox>
            </StackPane>
        </ScrollPane>
    </VBox>
</HBox>
