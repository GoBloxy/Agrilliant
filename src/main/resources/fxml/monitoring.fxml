<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.MonitoringController"
      spacing="14" styleClass="content-pane" prefWidth="1200" prefHeight="900">
    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

    <!-- Filters Bar -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <ComboBox fx:id="cmbFields" promptText="All Fields" styleClass="filter-combo"/>
        <ComboBox fx:id="cmbPlots" promptText="All Plots" styleClass="filter-combo"/>
        
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="date-picker-box">
            <DatePicker fx:id="datePicker" promptText="May 21, 2025"/>
        </HBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Button fx:id="btnRefreshCards" onAction="#onRefreshCards" styleClass="btn-secondary">
            <tooltip><Tooltip text="Refresh sensor cards now"/></tooltip>
            <graphic><FontIcon iconLiteral="fth-refresh-cw" iconSize="14"/></graphic>
        </Button>
        <MenuButton fx:id="btnAutoRefresh" text="Auto Refresh" styleClass="btn-secondary">
            <graphic><FontIcon iconLiteral="fth-refresh-cw" iconSize="14"/></graphic>
            <items>
                <MenuItem text="5 Seconds"/>
                <MenuItem text="30 Seconds"/>
                <MenuItem text="1 Minute"/>
                <MenuItem text="Off"/>
            </items>
        </MenuButton>
    </HBox>

    <!-- Top Section: Summary Cards -->
    <HBox spacing="14">
        <!-- Temperature -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fth-thermometer" iconSize="32" styleClass="icon-critical"/>
                <VBox spacing="2">
                    <Label text="Temperature" styleClass="summary-card-title"/>
                    <HBox alignment="BASELINE_LEFT" spacing="4">
                        <Label fx:id="lblTemp" text="--" styleClass="summary-card-value"/>
                        <Label text="°C" styleClass="summary-card-title"/>
                    </HBox>
                    <Label fx:id="lblTempSub" text="Waiting for data..." styleClass="text-muted"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Humidity -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fth-droplet" iconSize="32" styleClass="icon-info"/>
                <VBox spacing="2">
                    <Label text="Humidity" styleClass="summary-card-title"/>
                    <HBox alignment="BASELINE_LEFT" spacing="4">
                        <Label fx:id="lblHum" text="--" styleClass="summary-card-value"/>
                        <Label text="\%" styleClass="summary-card-title"/>
                    </HBox>
                    <Label fx:id="lblHumSub" text="Waiting for data..." styleClass="text-muted"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Soil Moisture -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="14">
                <FontIcon iconLiteral="fth-droplet" iconSize="32" styleClass="icon-warning"/>
                <VBox spacing="2">
                    <Label text="Soil Moisture" styleClass="summary-card-title"/>
                    <HBox alignment="BASELINE_LEFT" spacing="4">
                        <Label fx:id="lblSoil" text="--" styleClass="summary-card-value"/>
                        <Label text="\%" styleClass="summary-card-title"/>
                    </HBox>
                    <Label fx:id="lblSoilSub" text="Waiting for data..." styleClass="text-muted"/>
                </VBox>
            </HBox>
        </VBox>

    </HBox>

    <!-- Middle Section: Trend Chart & Sensor Map -->
    <HBox spacing="14">
        <!-- Temperature & Humidity Trend -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="600">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="Sensor Trend (Temp / Humidity / Soil)" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbChartPeriod" promptText="24 Hours" styleClass="filter-combo"/>
            </HBox>
            <LineChart fx:id="trendChart" prefHeight="260" maxHeight="260" legendVisible="true" animated="false" createSymbols="true">
                <xAxis><CategoryAxis fx:id="trendChartX" tickLabelsVisible="true"/></xAxis>
                <yAxis><NumberAxis fx:id="trendChartY" autoRanging="true"/></yAxis>
            </LineChart>
        </VBox>

        <!-- Sensor Map -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="400">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="Sensor Map" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbMapSensors" promptText="All Sensors" styleClass="filter-combo"/>
            </HBox>
            <StackPane fx:id="mapCanvasPane" VBox.vgrow="ALWAYS"
                       style="-fx-background-color:#1a3a1a;-fx-background-radius:8;"
                       prefHeight="260" maxHeight="Infinity">
                <Canvas fx:id="mapCanvas"/>
            </StackPane>
        </VBox>
    </HBox>

    <!-- Bottom Section: Live Readings & Sensor Status -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <!-- Live Sensor Readings -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="600">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <Label text="Live Sensor Readings" styleClass="card-title"/>
            <TableView fx:id="sensorTable" VBox.vgrow="ALWAYS" prefHeight="220">
                <columns>
                    <TableColumn fx:id="colPlot"    text="Plot"         prefWidth="130" reorderable="false" resizable="false"/>
                    <TableColumn fx:id="colType"    text="Sensor Type"  prefWidth="120" reorderable="false" resizable="false"/>
                    <TableColumn fx:id="colValue"   text="Value"        prefWidth="100" reorderable="false" resizable="false"/>
                    <TableColumn fx:id="colStatus"  text="Status"       prefWidth="90"  reorderable="false" resizable="false"/>
                    <TableColumn fx:id="colUpdated" text="Last Updated" prefWidth="120" reorderable="false" resizable="false"/>
                </columns>
            </TableView>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding><Insets top="8"/></padding>
                <Label fx:id="lblReadingsCount" text="Showing 1 to 6 of 10 readings" styleClass="pagination-text"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink text="View All Readings →" styleClass="link-end" onAction="#onViewAllReadings"/>
            </HBox>
        </VBox>

        <!-- Sensor Status -->
        <VBox styleClass="card" HBox.hgrow="ALWAYS" prefWidth="400">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <Label text="Sensor Status" styleClass="card-title"/>
            
            <HBox VBox.vgrow="ALWAYS" alignment="CENTER" spacing="20">
                <StackPane>
                    <PieChart fx:id="statusChart" prefWidth="180" prefHeight="180" legendVisible="false" labelsVisible="false"/>
                    <VBox alignment="CENTER" spacing="0">
                        <Label fx:id="lblTotalSensors" text="0" styleClass="donut-value"/>
                        <Label text="Total" styleClass="donut-label"/>
                    </VBox>
                </StackPane>
                
                <VBox alignment="CENTER_LEFT" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5" styleClass="legend-normal"/>
                        <Label text="Normal" prefWidth="80" styleClass="legend-text"/>
                        <Label fx:id="lblNormalCount" text="4 (80%)" styleClass="legend-text-right"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5" styleClass="legend-warning"/>
                        <Label text="Warning" prefWidth="80" styleClass="legend-text"/>
                        <Label fx:id="lblWarningCount" text="1 (20%)" styleClass="legend-text-right"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5" styleClass="legend-critical"/>
                        <Label text="Critical" prefWidth="80" styleClass="legend-text"/>
                        <Label fx:id="lblCriticalCount" text="0 (0%)" styleClass="legend-text-right"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5" styleClass="legend-offline"/>
                        <Label text="Offline" prefWidth="80" styleClass="legend-text"/>
                        <Label fx:id="lblOfflineCount" text="0 (0%)" styleClass="legend-text-right"/>
                    </HBox>
                </VBox>
            </HBox>
            <HBox alignment="BOTTOM_RIGHT">
                <Hyperlink text="View All Sensors →" styleClass="link-end" onAction="#onViewAllSensors"/>
            </HBox>
        </VBox>
    </HBox>

</VBox>
