<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<!--
  Mobile-first vertical stack: compact branding header on top, form below,
  footer at the bottom. Form fields fill the width up to a 480dp readability
  cap so they look right both on phone (full width) and desktop (centred
  content column inside a wider window).
-->
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.SignInController"
      styleClass="auth-root" alignment="TOP_CENTER" spacing="16">
    <padding><Insets top="32" right="24" bottom="24" left="24"/></padding>

    <!-- Compact branding header (logo + brand name) -->
    <VBox styleClass="auth-header,auth-brand-panel" alignment="CENTER" spacing="6">
        <ImageView styleClass="auth-logo" fitWidth="64" fitHeight="64" preserveRatio="true">
            <Image url="@/images/logo.png"/>
        </ImageView>
        <Label text="Agrilliant" styleClass="auth-app-name"/>
        <Label text="Smart Farming, Brighter Future" styleClass="auth-tagline"/>
    </VBox>

    <!-- Form column (capped at 480dp so it doesn't sprawl on desktop) -->
    <VBox alignment="TOP_CENTER" spacing="14" maxWidth="480" VBox.vgrow="ALWAYS" styleClass="auth-card">
        <VBox spacing="4" alignment="CENTER">
            <Label text="Welcome Back" styleClass="auth-title"/>
            <Label text="Sign in to your account to continue" styleClass="auth-subtitle"/>
        </VBox>

        <VBox spacing="10" maxWidth="Infinity">
            <TextField fx:id="txtEmail" promptText="Email address" styleClass="auth-field" maxWidth="Infinity"/>
            <PasswordField fx:id="txtPassword" promptText="Password" styleClass="auth-field" maxWidth="Infinity"/>
            <Hyperlink text="Forgot Password?" styleClass="auth-forgot" onAction="#onForgotPassword"/>
            <Label fx:id="lblError" styleClass="auth-error" visible="false" wrapText="true"/>
            <Button fx:id="btnSignIn" text="Sign In" styleClass="auth-btn" onAction="#onSignIn" maxWidth="Infinity"/>
        </VBox>

        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10">
            <Region HBox.hgrow="ALWAYS" styleClass="auth-divider-line"/>
            <Label text="OR" styleClass="auth-subtitle"/>
            <Region HBox.hgrow="ALWAYS" styleClass="auth-divider-line"/>
        </HBox>

        <!-- Fingerprint Login -->
        <VBox spacing="8" alignment="CENTER" maxWidth="Infinity">
            <Label text="Worker Fingerprint Login" styleClass="auth-subtitle"/>
            <Button fx:id="btnFingerprint" text="Scan Fingerprint"
                    styleClass="auth-btn-secondary" onAction="#onFingerprintLogin"
                    maxWidth="Infinity"/>
            <Label fx:id="lblFpStatus" text="" styleClass="auth-subtitle" visible="false" wrapText="true"/>
        </VBox>

        <HBox spacing="4" alignment="CENTER">
            <Label text="Don't have an account?" styleClass="auth-subtitle"/>
            <Hyperlink text="Sign Up" styleClass="auth-link" onAction="#onGoToSignUp"/>
        </HBox>
    </VBox>

    <!-- Footer pinned to bottom -->
    <Label text="© 2026 Agrilliant. All rights reserved." styleClass="auth-footer"/>
</VBox>
