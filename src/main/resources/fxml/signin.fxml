<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.SignInController"
      styleClass="auth-root" prefWidth="1100" prefHeight="700">

    <Region prefWidth="540" minWidth="540" maxWidth="540" styleClass="auth-image-panel"/>

    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="auth-form-panel">
        <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

        <HBox alignment="CENTER" spacing="0" styleClass="auth-tabs">
            <Button fx:id="btnTabSignIn" text="Sign In" styleClass="auth-tab,auth-tab-active" onAction="#onTabSignIn"/>
            <Button fx:id="btnTabSignUp" text="Sign Up" styleClass="auth-tab" onAction="#onGoToSignUp"/>
        </HBox>

        <Region prefHeight="24"/>

        <VBox spacing="4" alignment="CENTER">
            <Label text="Welcome back!" styleClass="auth-title"/>
            <Label text="Sign in to continue to your account" styleClass="auth-subtitle"/>
        </VBox>

        <Region prefHeight="20"/>

        <VBox spacing="14" alignment="CENTER_LEFT" maxWidth="380">
            <Label text="Email Address" styleClass="auth-label"/>
            <TextField fx:id="txtEmail" promptText="Enter your email" styleClass="auth-field"/>

            <HBox alignment="CENTER_LEFT">
                <Label text="Password" styleClass="auth-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink text="Forgot password?" styleClass="auth-forgot" onAction="#onForgotPassword"/>
            </HBox>
            <PasswordField fx:id="txtPassword" promptText="Enter your password" styleClass="auth-field"/>

            <CheckBox fx:id="chkRemember" text="Remember me" styleClass="auth-remember" selected="true"/>

            <Label fx:id="lblError" styleClass="auth-error" visible="false" managed="false"/>

            <Button fx:id="btnSignIn" text="→ Sign In" styleClass="auth-btn" onAction="#onSignIn"/>
        </VBox>

        <Region prefHeight="16"/>

        <HBox alignment="CENTER" spacing="10">
            <Region HBox.hgrow="ALWAYS" style="-fx-border-color:#e5e7eb;-fx-border-width:0 0 1 0;"/>
            <Label text="or continue with" styleClass="auth-divider-text"/>
            <Region HBox.hgrow="ALWAYS" style="-fx-border-color:#e5e7eb;-fx-border-width:0 0 1 0;"/>
        </HBox>

        <Region prefHeight="14"/>

        <HBox spacing="12" alignment="CENTER" maxWidth="380">
            <Button fx:id="btnFingerprint" text="Fingerprint" styleClass="auth-social-btn" onAction="#onFingerprintLogin" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Label fx:id="lblFpStatus" text="" styleClass="auth-subtitle" visible="false" managed="false"/>
        </HBox>

        <Region prefHeight="18"/>

        <HBox spacing="4" alignment="CENTER">
            <Label text="Don't have an account?" styleClass="auth-subtitle"/>
            <Hyperlink text="Sign up" styleClass="auth-link" onAction="#onGoToSignUp"/>
        </HBox>
    </VBox>
</HBox>