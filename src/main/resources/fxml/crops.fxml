<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import org.kordamp.ikonli.javafx.*?>

<StackPane styleClass="content-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="smartfarm.ui.CropController">

    <!-- ════════ VIEW 1: CROP LIST ════════ -->
    <VBox fx:id="listView" spacing="16">
        <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label styleClass="page-title" text="Crops" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnExport" onAction="#onExport" styleClass="btn-secondary" text="Export">
                <graphic><FontIcon iconLiteral="fth-download" iconSize="14" /></graphic>
            </Button>
            <Button fx:id="btnAddCrop" onAction="#onAddCrop" styleClass="btn-primary" text="+ Add Crop" />
        </HBox>

        <!--
          Summary cards: FlowPane wraps to 1 / 2 / 4 columns by width.
        -->
        <FlowPane hgap="16" vgap="16">
            <VBox spacing="6" styleClass="card" minWidth="200">
                <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane alignment="CENTER" prefHeight="42" prefWidth="42" style="-fx-background-color:#e8f5e9;-fx-background-radius:10;">
                        <FontIcon iconColor="#2e7d32" iconLiteral="fth-feather" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Total Crops" />
                        <Label fx:id="lblTotalCrops" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;" text="0" />
                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Active crops across all plots" />
                    </VBox>
                </HBox>
            </VBox>
            <VBox spacing="6" styleClass="card" minWidth="200">
                <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane alignment="CENTER" prefHeight="42" prefWidth="42" style="-fx-background-color:#dbeafe;-fx-background-radius:10;">
                        <FontIcon iconColor="#1d4ed8" iconLiteral="fth-sun" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Growing" />
                        <Label fx:id="lblGrowing" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;" text="0" />
                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Crops in growth phase" />
                    </VBox>
                </HBox>
            </VBox>
            <VBox spacing="6" styleClass="card" minWidth="200">
                <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane alignment="CENTER" prefHeight="42" prefWidth="42" style="-fx-background-color:#fef3c7;-fx-background-radius:10;">
                        <FontIcon iconColor="#d97706" iconLiteral="fth-check-circle" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Ready to Harvest" />
                        <Label fx:id="lblReady" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;" text="0" />
                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Ready for collection" />
                    </VBox>
                </HBox>
            </VBox>
            <VBox spacing="6" styleClass="card" minWidth="200">
                <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <StackPane alignment="CENTER" prefHeight="42" prefWidth="42" style="-fx-background-color:#fee2e2;-fx-background-radius:10;">
                        <FontIcon iconColor="#dc2626" iconLiteral="fth-alert-triangle" iconSize="18" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="At Risk" />
                        <Label fx:id="lblAtRisk" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;" text="0" />
                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Require attention" />
                    </VBox>
                </HBox>
            </VBox>
        </FlowPane>

        <!-- Filter row: FlowPane wraps search box + combos onto multiple rows on narrow screens. -->
        <FlowPane hgap="12" vgap="12">
            <HBox alignment="CENTER_LEFT" styleClass="search-box" minWidth="240" HBox.hgrow="NEVER">
                <padding><Insets left="8" right="8" /></padding>
                <FontIcon iconLiteral="fth-search" iconSize="14" styleClass="search-icon" />
                <TextField fx:id="txtSearch" promptText="Search crops..." styleClass="search-field" />
            </HBox>
            <ComboBox fx:id="cmbPlot" promptText="All Plots" styleClass="filter-combo" />
            <ComboBox fx:id="cmbStage" promptText="All Stages" styleClass="filter-combo" />
        </FlowPane>

        <!-- Table -->
        <VBox spacing="0" styleClass="card" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="8" left="8" right="8" top="8" /></padding>
            <TableView fx:id="cropTable" prefHeight="400" style="-fx-table-cell-border-color:transparent;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCropName" prefWidth="140" text="Crop Name" />
                    <TableColumn fx:id="colPlot" prefWidth="100" text="Plot" />
                    <TableColumn fx:id="colPlantedDate" prefWidth="120" text="Planted Date" />
                    <TableColumn fx:id="colHarvestDate" prefWidth="120" text="Harvest Date" />
                    <TableColumn fx:id="colStatus" prefWidth="100" text="Status" />
                    <TableColumn fx:id="colActions" prefWidth="100" text="Actions" />
                </columns>
            </TableView>
            <HBox alignment="CENTER_LEFT" style="-fx-padding:12 0 4 0;">
                <Label fx:id="lblPagination" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Showing 1 to 8 of 24 crops" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="4">
                    <Button styleClass="page-btn" text="&lt;" />
                    <Button styleClass="page-btn,page-btn-active" text="1" />
                    <Button styleClass="page-btn" text="2" />
                    <Button styleClass="page-btn" text="3" />
                    <Button styleClass="page-btn" text="&gt;" />
                </HBox>
            </HBox>
        </VBox>
    </VBox>

    <!-- ════════ VIEW 2: CROP DETAILS ════════ -->
    <VBox fx:id="detailView" managed="false" spacing="0" style="-fx-background-color:#f5f7fa;" visible="false">

        <!-- Detail Header -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:18 24 14 24;-fx-background-color:white;-fx-border-color:transparent transparent #e5e7eb transparent;-fx-border-width:0 0 1 0;">
            <Button onAction="#onBackToCrops" styleClass="icon-btn">
                <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="18" /></graphic>
            </Button>
            <Label styleClass="page-title" text="Crop Details" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAdvanceStage" onAction="#onAdvanceStage" styleClass="btn-primary" text="Advance Stage">
                <graphic><FontIcon iconLiteral="fth-trending-up" iconSize="14" /></graphic>
            </Button>
        </HBox>

        <!-- Tab Bar -->
        <HBox fx:id="tabBar" spacing="0" style="-fx-padding:0 24 0 24;-fx-background-color:white;-fx-border-color:transparent transparent #e5e7eb transparent;-fx-border-width:0 0 1 0;">
            <Button fx:id="tabOverview" onAction="#onTabOverview" styleClass="crop-tab,crop-tab-active" text="Overview" />
            <Button fx:id="tabTimeline" onAction="#onTabTimeline" styleClass="crop-tab" text="Growth Timeline" />
            <Button fx:id="tabHistory" onAction="#onTabHistory" styleClass="crop-tab" text="Care History" />
            <Button fx:id="tabPhotos" onAction="#onTabPhotos" styleClass="crop-tab" text="Photos" />
            <Button fx:id="tabNotes" onAction="#onTabNotes" styleClass="crop-tab" text="Notes" />
        </HBox>

        <!-- Tab Content Area -->
        <ScrollPane fitToWidth="true" style="-fx-background-color:#f5f7fa;" styleClass="page-scroll" VBox.vgrow="ALWAYS">
            <StackPane fx:id="tabContent" style="-fx-padding:20 24 24 24;">

                <!-- ═══ OVERVIEW TAB ═══ -->
                <VBox fx:id="overviewPane" spacing="16">

                    <!-- ROW 1: Crop Info + Growth Progress + Health -->
                    <HBox spacing="16">

                        <!-- LEFT: Crop Info Card -->
                        <VBox minWidth="250" prefWidth="270" spacing="14" styleClass="card">
                            <padding><Insets bottom="24" left="20" right="20" top="24" /></padding>
                            <VBox alignment="CENTER" spacing="6">
                                <StackPane alignment="CENTER" prefHeight="64" prefWidth="64" style="-fx-background-color:#e8f5e9;-fx-background-radius:100;">
                                    <FontIcon iconColor="#2e7d32" iconLiteral="fth-feather" iconSize="28" />
                                </StackPane>
                                <Label fx:id="lblDetailName" style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Wheat" />
                                <Label fx:id="lblDetailPlot" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Plot 1 - North Field" />
                                <HBox alignment="CENTER">
                                    <Label fx:id="lblDetailStatus" style="-fx-background-color:#d1fae5;-fx-text-fill:#065f46;-fx-padding:3 12;-fx-background-radius:12;-fx-font-size:11;-fx-font-weight:bold;" text="Active" />
                                </HBox>
                            </VBox>
                            <Separator />
                            <Label fx:id="lblDetailPlanted" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Planted  Apr 1, 2025" />
                            <HBox spacing="0">
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Area" />
                                        <Label fx:id="lblDetailArea" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="2.5 ha" />
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Days Planted" />
                                        <Label fx:id="lblDetailDays" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="50 days" />
                                    </VBox>
                                </VBox>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Growth Stage" />
                                        <Label fx:id="lblDetailStage" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Vegetative" />
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Expected Harvest" />
                                        <Label fx:id="lblDetailHarvest" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Jun 30, 2025" />
                                    </VBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- CENTER: Growth Progress Donut -->
                        <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Growth Progress" />
                            <HBox alignment="CENTER" spacing="20">
                                <StackPane prefHeight="160" prefWidth="160">
                                    <Circle fill="transparent" radius="70" stroke="#e5e7eb" strokeWidth="14" />
                                    <Circle fx:id="progressArc" fill="transparent" radius="70" rotate="-90" stroke="#2e7d32" strokeDashOffset="0" strokeWidth="14" />
                                    <VBox alignment="CENTER" spacing="0">
                                        <Label fx:id="lblProgressPercent" style="-fx-font-size:28;-fx-font-weight:bold;-fx-text-fill:#111827;" text="65%" />
                                        <Label style="-fx-font-size:10;-fx-text-fill:#9ca3af;" text="Complete" />
                                    </VBox>
                                </StackPane>
                                <VBox spacing="12">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Circle fill="#2e7d32" radius="5" />
                                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Current" />
                                        <Label fx:id="lblTargetProgress" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#111827;" text="100%" />
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Circle fill="#3b82f6" radius="5" />
                                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Expected" />
                                        <Label fx:id="lblExpectedProgress" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#111827;" text="70%" />
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Circle fill="#dc2626" radius="5" />
                                        <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Behind" />
                                        <Label fx:id="lblBehindSchedule" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#111827;" text="5%" />
                                    </HBox>
                                </VBox>
                            </HBox>
                            <Separator />
                            <HBox spacing="16">
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Next Milestone" />
                                    <Label fx:id="lblNextMilestone" style="-fx-font-size:12;-fx-text-fill:#374151;" text="Heading Stage" />
                                </VBox>
                                <VBox spacing="4">
                                    <Label style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#111827;" text="ETA" />
                                    <Label fx:id="lblMilestoneEta" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="15 days" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- RIGHT: Health Indicators -->
                        <VBox minWidth="210" prefWidth="230" spacing="14" styleClass="card">
                            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Health Indicators" />
                            <VBox spacing="12">
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Overall Health" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblHealthOverall" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#16a34a;" text="Good" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Leaf Color" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblHealthLeaf" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#16a34a;" text="Good" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Growth Rate" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblHealthGrowth" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#16a34a;" text="Good" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Pest Level" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblHealthPest" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#3b82f6;" text="Low" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Disease Risk" HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblHealthDisease" style="-fx-font-size:12;-fx-font-weight:bold;-fx-text-fill:#3b82f6;" text="Low" />
                                </HBox>
                            </VBox>
                            <Separator />
                            <VBox spacing="6">
                                <Label style="-fx-font-size:14;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Yield Estimate" />
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <Label fx:id="lblYieldEstimate" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#2e7d32;" text="0 kg" />
                                    <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="expected" />
                                </HBox>
                                <StackPane prefHeight="8" style="-fx-pref-height:8;-fx-background-color:#e5e7eb;-fx-background-radius:4;">
                                    <StackPane fx:id="yieldBar" alignment="CENTER_LEFT" maxWidth="180" prefHeight="8" style="-fx-background-color:#2e7d32;-fx-background-radius:4;" />
                                </StackPane>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- ROW 2: Growth Stage Timeline + Environmental Conditions -->
                    <HBox spacing="16">

                        <!-- Growth Stage Visual Timeline -->
                        <VBox spacing="16" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="20" left="24" right="24" top="20" /></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Growth Stage Timeline" />

                            <!-- Stage Pipeline -->
                            <HBox fx:id="stageTimeline" alignment="CENTER" spacing="0" style="-fx-padding:12 0 8 0;">
                                <!-- Dynamically populated: stage circles + connecting lines -->
                            </HBox>

                            <!-- Stage Labels Row -->
                            <HBox fx:id="stageLabels" alignment="CENTER" spacing="0">
                                <!-- Dynamically populated: labels below each stage -->
                            </HBox>

                            <Separator />

                            <!-- Days remaining countdown -->
                            <HBox alignment="CENTER_LEFT" spacing="24">
                                <VBox spacing="2">
                                    <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Days Elapsed" />
                                    <Label fx:id="lblElapsedDays" style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#111827;" text="50" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Days Remaining" />
                                    <Label fx:id="lblRemainingDays" style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#2e7d32;" text="40" />
                                </VBox>
                                <VBox spacing="2">
                                    <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Total Lifecycle" />
                                    <Label fx:id="lblTotalLifecycle" style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#6b7280;" text="90 days" />
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <VBox alignment="CENTER_RIGHT" spacing="2">
                                    <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Completion" />
                                    <ProgressBar fx:id="lifecycleBar" prefHeight="10" prefWidth="140" progress="0.55" style="-fx-accent:#2e7d32;" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Environmental Conditions (from sensor) -->
                        <VBox minWidth="260" prefWidth="280" spacing="14" styleClass="card">
                            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <FontIcon iconColor="#2e7d32" iconLiteral="fth-thermometer" iconSize="16" />
                                <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Plot Conditions" />
                            </HBox>
                            <Label fx:id="lblConditionsSource" style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Live from sensors" />

                            <!-- Temperature -->
                            <VBox spacing="4" style="-fx-background-color:#f0fdf4;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#dc2626" iconLiteral="fth-sun" iconSize="14" />
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Temperature" />
                                </HBox>
                                <Label fx:id="lblEnvTemp" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- °C" />
                                <Label fx:id="lblEnvTempStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal" />
                            </VBox>

                            <!-- Humidity -->
                            <VBox spacing="4" style="-fx-background-color:#eff6ff;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fth-droplet" iconSize="14" />
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Humidity" />
                                </HBox>
                                <Label fx:id="lblEnvHumidity" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- %" />
                                <Label fx:id="lblEnvHumStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal" />
                            </VBox>

                            <!-- Soil Moisture -->
                            <VBox spacing="4" style="-fx-background-color:#fefce8;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#ca8a04" iconLiteral="fth-activity" iconSize="14" />
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Soil Moisture" />
                                </HBox>
                                <Label fx:id="lblEnvSoil" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- %" />
                                <Label fx:id="lblEnvSoilStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal" />
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ═══ GROWTH TIMELINE TAB ═══ -->
                <VBox fx:id="timelinePane" managed="false" spacing="16" visible="false">
                    <VBox spacing="16" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20" /></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Growth Stage History" />
                        <VBox fx:id="timelineEntries" spacing="0">
                            <!-- Populated dynamically -->
                        </VBox>
                    </VBox>
                </VBox>

                <!-- ═══ CARE HISTORY TAB ═══ -->
                <VBox fx:id="historyPane" managed="false" spacing="16" visible="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20" /></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Care &amp; Activity Log" />
                        <Label style="-fx-font-size:13;-fx-text-fill:#6b7280;" text="Activities such as watering, fertilizing, and pest control will appear here." />
                        <VBox fx:id="careEntries" spacing="0">
                            <!-- Populated dynamically -->
                        </VBox>
                    </VBox>
                </VBox>

                <!-- ═══ PHOTOS TAB ═══ -->
                <VBox fx:id="photosPane" managed="false" spacing="16" visible="false">
                    <VBox alignment="CENTER" spacing="12" styleClass="card">
                        <padding><Insets bottom="40" left="24" right="24" top="40" /></padding>
                        <FontIcon iconColor="#9ca3af" iconLiteral="fth-camera" iconSize="48" />
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#374151;" text="No Photos Yet" />
                        <Label style="-fx-font-size:13;-fx-text-fill:#6b7280;" text="Upload crop photos to track visual progress over time." />
                    </VBox>
                </VBox>

                <!-- ═══ NOTES TAB ═══ -->
                <VBox fx:id="notesPane" managed="false" spacing="16" visible="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20" /></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Notes" />
                        <TextArea fx:id="txtNotes" prefHeight="200" promptText="Add notes about this crop..." style="-fx-font-size:13;-fx-border-color:#e5e7eb;-fx-border-radius:8;-fx-background-radius:8;" />
                    </VBox>
                </VBox>

            </StackPane>
        </ScrollPane>
    </VBox>
</StackPane>
