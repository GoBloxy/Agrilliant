<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.PlotController"
           styleClass="content-pane" prefWidth="1200" prefHeight="900">

    <!-- ════════ VIEW 1: PLOT LIST ════════ -->
    <VBox fx:id="listView" spacing="14">
    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Plots &amp; Fields" styleClass="page-title"/>
    </HBox>

    <!-- Summary Cards -->
    <HBox spacing="14" alignment="CENTER_LEFT">
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: #e8f5e9; -fx-background-radius: 100;" prefWidth="44" prefHeight="44" minWidth="44">
                    <FontIcon iconLiteral="fth-grid" iconSize="20" iconColor="#2e7d32"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Total Plots" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                    <Label fx:id="lblTotalPlots" text="0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="Across all fields" style="-fx-font-size: 10; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: #e8f5e9; -fx-background-radius: 100;" prefWidth="44" prefHeight="44" minWidth="44">
                    <FontIcon iconLiteral="fth-sun" iconSize="20" iconColor="#2e7d32"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Under Cultivation" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                    <Label fx:id="lblCultivation" text="0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="Plots with active crops" style="-fx-font-size: 10; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: #fef3c7; -fx-background-radius: 100;" prefWidth="44" prefHeight="44" minWidth="44">
                    <FontIcon iconLiteral="fth-maximize" iconSize="20" iconColor="#d97706"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Available" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                    <Label fx:id="lblAvailable" text="0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="Ready for planting" style="-fx-font-size: 10; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color: #f3e8ff; -fx-background-radius: 100;" prefWidth="44" prefHeight="44" minWidth="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20" iconColor="#9333ea"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Fallow" style="-fx-font-size: 11; -fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
                    <Label fx:id="lblFallow" text="0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Label text="Not in use" style="-fx-font-size: 10; -fx-text-fill: #9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="btnAddPlot" text="+ Add New Plot" styleClass="btn-primary" style="-fx-padding: 10 18;" onAction="#onAddPlot"/>
            <Button fx:id="btnExport" text="Export" styleClass="btn-secondary" style="-fx-padding: 10 18;" onAction="#onExport">
                <graphic><FontIcon iconLiteral="fth-download" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <!-- Filters Row -->
    <HBox spacing="14" alignment="CENTER_LEFT">
        <HBox alignment="CENTER_LEFT" styleClass="search-box">
            <padding><Insets right="8" left="8"/></padding>
            <TextField fx:id="txtSearch" promptText="Search plots..." styleClass="search-field"/>
            <Region HBox.hgrow="ALWAYS"/>
            <FontIcon iconLiteral="fth-search" iconSize="14" styleClass="search-icon"/>
        </HBox>
        <ComboBox fx:id="cmbField" promptText="All Fields" styleClass="filter-combo"/>
        <ComboBox fx:id="cmbStatus" promptText="All Status" styleClass="filter-combo"/>
        <ComboBox fx:id="cmbCrop" promptText="All Crops" styleClass="filter-combo"/>
    </HBox>

    <!-- Map + Overview -->
    <HBox spacing="14">
        <VBox styleClass="card" HBox.hgrow="ALWAYS">
            <StackPane prefHeight="380" style="-fx-background-color: #2d5a27; -fx-background-radius: 10;">
                <ImageView fitHeight="380" fitWidth="780" preserveRatio="false" style="-fx-opacity: 0.95;" mouseTransparent="true">
                    <image><Image url="@../images/farm_map.png"/></image>
                </ImageView>
                <Pane fx:id="plotMapPane" style="-fx-background-color: transparent;"/>
                <VBox spacing="4" StackPane.alignment="TOP_LEFT" pickOnBounds="false"
                      maxWidth="-Infinity" maxHeight="-Infinity">
                    <padding><Insets top="10" left="10"/></padding>
                    <Button text="+" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 4 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    <Button text="—" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 4 10; -fx-cursor: hand;"/>
                    <Button style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 6; -fx-cursor: hand;">
                        <graphic><FontIcon iconLiteral="fth-crosshair" iconSize="14"/></graphic>
                    </Button>
                    <Region prefHeight="6"/>
                    <ToggleButton fx:id="btnDrawMode" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 6; -fx-cursor: hand;">
                        <graphic><FontIcon iconLiteral="fth-edit-3" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="Draw Plot: click to add points, double-click to finish"/></tooltip>
                    </ToggleButton>
                    <Button fx:id="btnDeletePlot" style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 6; -fx-cursor: hand;">
                        <graphic><FontIcon iconLiteral="fth-trash-2" iconSize="14"/></graphic>
                        <tooltip><Tooltip text="Delete last drawn plot"/></tooltip>
                    </Button>
                </VBox>
            </StackPane>
        </VBox>

        <VBox styleClass="card" prefWidth="380" minWidth="380" spacing="12">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <Label text="Plot Overview" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <StackPane fx:id="chartContainer" prefWidth="130" prefHeight="130" minWidth="130">
                    <VBox alignment="CENTER" spacing="0" mouseTransparent="true">
                        <Label fx:id="lblChartTotal" text="0" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label text="Total Plots" style="-fx-font-size: 9; -fx-text-fill: #6b7280;"/>
                    </VBox>
                </StackPane>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Circle radius="5" fill="#28a745"/>
                        <Label text="Under Cultivation" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblLegendCultivation" text="0 (0%)" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Circle radius="5" fill="#ffc107"/>
                        <Label text="Available" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblLegendAvailable" text="0 (0%)" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Circle radius="5" fill="#6f42c1"/>
                        <Label text="Fallow" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblLegendFallow" text="0 (0%)" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    </HBox>
                </VBox>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <VBox HBox.hgrow="ALWAYS">
                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fth-map" iconSize="11" iconColor="#9ca3af"/>
                        <Label text="Total Area" style="-fx-font-size: 10; -fx-text-fill: #6b7280;"/>
                    </HBox>
                    <Label fx:id="lblTotalArea" text="0.0 ha" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS">
                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fth-map" iconSize="11" iconColor="#9ca3af"/>
                        <Label text="Cultivated Area" style="-fx-font-size: 10; -fx-text-fill: #6b7280;"/>
                    </HBox>
                    <Label fx:id="lblCultivatedArea" text="0.0 ha" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS">
                    <HBox spacing="4" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fth-map" iconSize="11" iconColor="#9ca3af"/>
                        <Label text="Available Area" style="-fx-font-size: 10; -fx-text-fill: #6b7280;"/>
                    </HBox>
                    <Label fx:id="lblAvailableArea" text="0.0 ha" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                </VBox>
            </HBox>
            <Separator/>
            <VBox spacing="8">
                <Label text="Plot Status" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#28a745"/>
                    <Label text="Under Cultivation" prefWidth="115" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    <Label fx:id="lblStatusCultCount" text="0" style="-fx-font-size: 11; -fx-text-fill: #374151;" prefWidth="25"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Active crops growing" style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#ffc107"/>
                    <Label text="Available" prefWidth="115" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    <Label fx:id="lblStatusAvailCount" text="0" style="-fx-font-size: 11; -fx-text-fill: #374151;" prefWidth="25"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Ready for planting" style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Circle radius="4" fill="#6f42c1"/>
                    <Label text="Fallow" prefWidth="115" style="-fx-font-size: 11; -fx-text-fill: #374151;"/>
                    <Label fx:id="lblStatusFallowCount" text="0" style="-fx-font-size: 11; -fx-text-fill: #374151;" prefWidth="25"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Not in use" style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- All Plots Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="All Plots" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <TableView fx:id="plotTable" VBox.vgrow="ALWAYS" prefHeight="250" style="-fx-fixed-cell-size: 46;">
            <columns>
                <TableColumn fx:id="colPlotId" text="Plot ID" prefWidth="160" minWidth="120" reorderable="false"/>
                <TableColumn fx:id="colField" text="Field" prefWidth="100" minWidth="80" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colCrop" text="Crop" prefWidth="110" minWidth="90" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colArea" text="Area (ha)" prefWidth="75" minWidth="65" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="140" minWidth="120" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colSoil" text="Soil Type" prefWidth="95" minWidth="80" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colIrrigation" text="Irrigation" prefWidth="95" minWidth="80" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colLastActivity" text="Last Activity" prefWidth="130" minWidth="110" reorderable="false" resizable="false"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="95" minWidth="95" reorderable="false" resizable="false" sortable="false"/>
            </columns>
        </TableView>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblPagination" text="" style="-fx-font-size: 11; -fx-text-fill: #6b7280;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="4">
                <Button text="&lt;" styleClass="page-btn"/>
                <Button text="1" styleClass="page-btn,page-btn-active"/>
                <Button text="2" styleClass="page-btn"/>
                <Button text="&gt;" styleClass="page-btn"/>
            </HBox>
        </HBox>
    </VBox>
    </VBox>

    <!-- ════════ VIEW 2: PLOT DETAILS ════════ -->
    <VBox fx:id="detailView" managed="false" spacing="0" style="-fx-background-color:#f5f7fa;" visible="false">

        <!-- Detail Header -->
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding:18 24 14 24;-fx-background-color:white;-fx-border-color:transparent transparent #e5e7eb transparent;-fx-border-width:0 0 1 0;">
            <Button onAction="#onBackToPlots" styleClass="icon-btn">
                <graphic><FontIcon iconLiteral="fth-arrow-left" iconSize="18"/></graphic>
            </Button>
            <Label styleClass="page-title" text="Plot Details"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnEditPlotDetail" onAction="#onEditPlotFromDetail" styleClass="btn-secondary" text="Edit Plot">
                <graphic><FontIcon iconLiteral="fth-edit-2" iconSize="14"/></graphic>
            </Button>
        </HBox>

        <!-- Tab Bar -->
        <HBox fx:id="plotTabBar" spacing="0" style="-fx-padding:0 24 0 24;-fx-background-color:white;-fx-border-color:transparent transparent #e5e7eb transparent;-fx-border-width:0 0 1 0;">
            <Button fx:id="plotTabOverview" onAction="#onPlotTabOverview" styleClass="crop-tab,crop-tab-active" text="Overview"/>
            <Button fx:id="plotTabCrops" onAction="#onPlotTabCrops" styleClass="crop-tab" text="Crops"/>
            <Button fx:id="plotTabSensors" onAction="#onPlotTabSensors" styleClass="crop-tab" text="Sensor Data"/>
            <Button fx:id="plotTabNotes" onAction="#onPlotTabNotes" styleClass="crop-tab" text="Notes"/>
        </HBox>

        <!-- Tab Content -->
        <ScrollPane fitToWidth="true" style="-fx-background-color:#f5f7fa;" styleClass="page-scroll" VBox.vgrow="ALWAYS">
            <StackPane fx:id="plotTabContent" style="-fx-padding:20 24 24 24;">

                <!-- ═══ OVERVIEW TAB ═══ -->
                <VBox fx:id="plotOverviewPane" spacing="16">

                    <!-- ROW 1: Plot Info + Conditions + Irrigation -->
                    <HBox spacing="16">

                        <!-- LEFT: Plot Info Card -->
                        <VBox minWidth="250" prefWidth="280" spacing="14" styleClass="card">
                            <padding><Insets bottom="24" left="20" right="20" top="24"/></padding>
                            <VBox alignment="CENTER" spacing="6">
                                <StackPane alignment="CENTER" prefHeight="64" prefWidth="64" style="-fx-background-color:#e8f5e9;-fx-background-radius:100;">
                                    <FontIcon iconColor="#2e7d32" iconLiteral="fth-map-pin" iconSize="28"/>
                                </StackPane>
                                <Label fx:id="lblPlotDetailName" style="-fx-font-size:18;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Plot 1"/>
                                <Label fx:id="lblPlotDetailLocation" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Main Field"/>
                                <HBox alignment="CENTER">
                                    <Label fx:id="lblPlotDetailStatus" style="-fx-background-color:#d1fae5;-fx-text-fill:#065f46;-fx-padding:3 12;-fx-background-radius:12;-fx-font-size:11;-fx-font-weight:bold;" text="Active"/>
                                </HBox>
                            </VBox>
                            <Separator/>
                            <Label fx:id="lblPlotDetailCreated" style="-fx-font-size:12;-fx-text-fill:#6b7280;" text="Created  —"/>
                            <HBox spacing="0">
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Area"/>
                                        <Label fx:id="lblPlotDetailArea" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="0 acres"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Soil Type"/>
                                        <Label fx:id="lblPlotDetailSoil" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="—"/>
                                    </VBox>
                                </VBox>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Irrigation"/>
                                        <Label fx:id="lblPlotDetailIrrigation" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="—"/>
                                    </VBox>
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Last Updated"/>
                                        <Label fx:id="lblPlotDetailUpdated" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:#111827;" text="—"/>
                                    </VBox>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- CENTER: Active Crops -->
                        <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Active Crops"/>
                            <VBox fx:id="plotDetailCropsBox" spacing="8">
                                <Label text="No active crops" style="-fx-text-fill:#9ca3af;-fx-font-size:12;"/>
                            </VBox>
                        </VBox>

                        <!-- RIGHT: Plot Conditions -->
                        <VBox minWidth="260" prefWidth="280" spacing="14" styleClass="card">
                            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="6">
                                <FontIcon iconColor="#2e7d32" iconLiteral="fth-thermometer" iconSize="16"/>
                                <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Plot Conditions"/>
                            </HBox>
                            <Label fx:id="lblPlotCondSource" style="-fx-font-size:11;-fx-text-fill:#9ca3af;" text="Last recorded reading"/>

                            <!-- Temperature -->
                            <VBox spacing="4" style="-fx-background-color:#f0fdf4;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#dc2626" iconLiteral="fth-sun" iconSize="14"/>
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Temperature"/>
                                </HBox>
                                <Label fx:id="lblPlotTemp" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- °C"/>
                                <Label fx:id="lblPlotTempStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal"/>
                            </VBox>

                            <!-- Humidity -->
                            <VBox spacing="4" style="-fx-background-color:#eff6ff;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#2563eb" iconLiteral="fth-droplet" iconSize="14"/>
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Humidity"/>
                                </HBox>
                                <Label fx:id="lblPlotHumidity" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- %"/>
                                <Label fx:id="lblPlotHumStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal"/>
                            </VBox>

                            <!-- Soil Moisture -->
                            <VBox spacing="4" style="-fx-background-color:#fefce8;-fx-background-radius:8;-fx-padding:12;">
                                <HBox alignment="CENTER_LEFT" spacing="6">
                                    <FontIcon iconColor="#ca8a04" iconLiteral="fth-activity" iconSize="14"/>
                                    <Label style="-fx-font-size:11;-fx-text-fill:#6b7280;" text="Soil Moisture"/>
                                </HBox>
                                <Label fx:id="lblPlotSoilMoisture" style="-fx-font-size:20;-fx-font-weight:bold;-fx-text-fill:#111827;" text="-- %"/>
                                <Label fx:id="lblPlotSoilStatus" style="-fx-font-size:10;-fx-text-fill:#16a34a;-fx-font-weight:bold;" text="Normal"/>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- ROW 2: Soil Profile + Plot Activity -->
                    <HBox spacing="16">
                        <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="20" left="24" right="24" top="20"/></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Soil Profile"/>
                            <VBox fx:id="soilProfileBox" spacing="10">
                            </VBox>
                        </VBox>

                        <VBox minWidth="280" prefWidth="300" spacing="14" styleClass="card">
                            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
                            <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Plot Summary"/>
                            <VBox fx:id="plotSummaryBox" spacing="10">
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ═══ CROPS TAB ═══ -->
                <VBox fx:id="plotCropsPane" managed="false" spacing="16" visible="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20"/></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Crops on this Plot"/>
                        <VBox fx:id="plotCropsListBox" spacing="8">
                        </VBox>
                    </VBox>
                </VBox>

                <!-- ═══ SENSOR DATA TAB ═══ -->
                <VBox fx:id="plotSensorsPane" managed="false" spacing="16" visible="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20"/></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Sensor Reading History"/>
                        <VBox fx:id="sensorHistoryBox" spacing="4">
                        </VBox>
                    </VBox>
                </VBox>

                <!-- ═══ NOTES TAB ═══ -->
                <VBox fx:id="plotNotesPane" managed="false" spacing="16" visible="false">
                    <VBox spacing="12" styleClass="card">
                        <padding><Insets bottom="24" left="24" right="24" top="20"/></padding>
                        <Label style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#111827;" text="Notes"/>
                        <TextArea fx:id="txtPlotNotes" prefHeight="200" promptText="Add notes about this plot..." style="-fx-font-size:13;-fx-border-color:#e5e7eb;-fx-border-radius:8;-fx-background-radius:8;"/>
                    </VBox>
                </VBox>

            </StackPane>
        </ScrollPane>
    </VBox>
</StackPane>
