<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<!--
  Mobile-first vertical stack — same shape as signin.fxml. See its header
  comment for layout rationale.
-->
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.SignUpController"
      styleClass="auth-root" alignment="TOP_CENTER" spacing="14">
    <padding><Insets top="28" right="24" bottom="24" left="24"/></padding>

    <!-- Compact branding header -->
    <VBox styleClass="auth-header" alignment="CENTER" spacing="6">
        <ImageView styleClass="auth-logo" fitWidth="64" fitHeight="64" preserveRatio="true">
            <Image url="@/images/logo.png"/>
        </ImageView>
        <Label text="Agrilliant" styleClass="auth-app-name"/>
    </VBox>

    <!-- Form column -->
    <VBox alignment="TOP_CENTER" spacing="12" maxWidth="480" VBox.vgrow="ALWAYS" styleClass="auth-card">
        <VBox spacing="4" alignment="CENTER">
            <Label text="Create Account" styleClass="auth-title"/>
            <Label text="Join Agrilliant to manage your farm" styleClass="auth-subtitle"/>
        </VBox>

        <VBox spacing="8" maxWidth="Infinity">
            <TextField fx:id="txtFullName" promptText="Full Name" styleClass="auth-field" maxWidth="Infinity"/>
            <TextField fx:id="txtUsername" promptText="Username" styleClass="auth-field" maxWidth="Infinity"/>
            <TextField fx:id="txtEmail" promptText="Email address" styleClass="auth-field" maxWidth="Infinity"/>
            <TextField fx:id="txtPhone" promptText="Phone (optional)" styleClass="auth-field" maxWidth="Infinity"/>
            <PasswordField fx:id="txtPassword" promptText="Password" styleClass="auth-field" maxWidth="Infinity"/>
            <PasswordField fx:id="txtConfirm" promptText="Confirm Password" styleClass="auth-field" maxWidth="Infinity"/>
            <ComboBox fx:id="cmbRole" promptText="Role" styleClass="auth-combo" maxWidth="Infinity"/>
            <Label fx:id="lblError" styleClass="auth-error" visible="false" wrapText="true"/>
            <Button fx:id="btnSignUp" text="Sign Up" styleClass="auth-btn" onAction="#onSignUp" maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="4" alignment="CENTER">
            <Label text="Already have an account?" styleClass="auth-subtitle"/>
            <Hyperlink text="Sign In" styleClass="auth-link" onAction="#onGoToSignIn"/>
        </HBox>
    </VBox>
</VBox>
