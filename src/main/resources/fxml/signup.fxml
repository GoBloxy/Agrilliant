<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.SignUpController"
      styleClass="auth-root" prefWidth="1100" prefHeight="700">

    <Region prefWidth="540" minWidth="540" maxWidth="540" styleClass="auth-image-panel"/>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" HBox.hgrow="ALWAYS" styleClass="auth-scroll">
        <VBox alignment="CENTER" styleClass="auth-form-panel">
            <padding><Insets top="30" right="60" bottom="30" left="60"/></padding>

            <HBox alignment="CENTER" spacing="0" styleClass="auth-tabs">
                <Button text="Sign In" styleClass="auth-tab" onAction="#onGoToSignIn"/>
                <Button text="Sign Up" styleClass="auth-tab,auth-tab-active"/>
            </HBox>

            <Region prefHeight="20"/>

            <VBox spacing="4" alignment="CENTER">
                <Label text="Create Account" styleClass="auth-title"/>
                <Label text="Join Agrilliant to manage your farm" styleClass="auth-subtitle"/>
            </VBox>

            <Region prefHeight="16"/>

            <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="380">
                <Label text="Full Name" styleClass="auth-label"/>
                <TextField fx:id="txtFullName" promptText="Enter your full name" styleClass="auth-field"/>

                <Label text="Username" styleClass="auth-label"/>
                <TextField fx:id="txtUsername" promptText="Choose a username" styleClass="auth-field"/>

                <Label text="Email Address" styleClass="auth-label"/>
                <TextField fx:id="txtEmail" promptText="Enter your email" styleClass="auth-field"/>

                <Label text="Phone (optional)" styleClass="auth-label"/>
                <TextField fx:id="txtPhone" promptText="Enter your phone number" styleClass="auth-field"/>

                <Label text="Password" styleClass="auth-label"/>
                <PasswordField fx:id="txtPassword" promptText="Create a password" styleClass="auth-field"/>

                <Label text="Confirm Password" styleClass="auth-label"/>
                <PasswordField fx:id="txtConfirm" promptText="Confirm your password" styleClass="auth-field"/>

                <Label text="Role" styleClass="auth-label"/>
                <ComboBox fx:id="cmbRole" promptText="Select role" styleClass="auth-combo"/>

                <Label fx:id="lblError" styleClass="auth-error" visible="false" managed="false"/>

                <Region prefHeight="4"/>

                <Button fx:id="btnSignUp" text="→ Sign Up" styleClass="auth-btn" onAction="#onSignUp"/>
            </VBox>

            <Region prefHeight="16"/>

            <HBox spacing="4" alignment="CENTER">
                <Label text="Already have an account?" styleClass="auth-subtitle"/>
                <Hyperlink text="Sign in" styleClass="auth-link" onAction="#onGoToSignIn"/>
            </HBox>

            <Region prefHeight="16"/>
        </VBox>
    </ScrollPane>
</HBox>