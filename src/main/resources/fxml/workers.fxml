<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import com.gluonhq.charm.glisten.control.CharmListView?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.WorkerController"
      spacing="14" styleClass="content-pane">
    <padding><Insets top="14" right="18" bottom="14" left="18"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Users and Workers" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddWorker" text="+ Add Worker" styleClass="btn-primary" onAction="#onAddWorker"/>
    </HBox>

    <!--
      Summary cards: FlowPane wraps to 1 / 2 / 4 columns depending on width.
      Card minWidth=200 forces a wrap when (200*N + hgap*(N-1)) > available.
        Phone (≤460dp):  1 column × 4
        Tablet (~860dp): 2 columns × 2
        Desktop ≥860dp:  4 columns × 1
    -->
    <FlowPane hgap="12" vgap="12" prefWrapLength="200">
        <VBox styleClass="card" minWidth="200" spacing="8">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-users" iconSize="20" iconColor="#2e7d32"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Total Workers" styleClass="summary-card-title"/>
                    <Label fx:id="lblTotalWorkers" text="0" styleClass="summary-card-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="8">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-primary" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="20" iconColor="#065f46"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="On Duty" styleClass="summary-card-title"/>
                    <Label fx:id="lblOnDuty" text="0" styleClass="summary-card-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="8">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-warning" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-clock" iconSize="20" iconColor="#d97706"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Available" styleClass="summary-card-title"/>
                    <Label fx:id="lblAvailable" text="0" styleClass="summary-card-value"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" minWidth="200" spacing="8">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane styleClass="metric-icon,metric-icon-error" prefWidth="44" prefHeight="44">
                    <FontIcon iconLiteral="fth-alert-circle" iconSize="20" iconColor="#dc2626"/>
                </StackPane>
                <VBox spacing="0">
                    <Label text="Busy" styleClass="summary-card-title"/>
                    <Label fx:id="lblBusy" text="0" style="-fx-font-size:22;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>
        </VBox>
    </FlowPane>

    <!-- Filter row: FlowPane wraps search box + combos onto multiple rows on narrow screens. -->
    <FlowPane hgap="12" vgap="12">
        <HBox alignment="CENTER_LEFT" styleClass="search-box" minWidth="240" HBox.hgrow="NEVER">
            <padding><Insets right="8" left="8"/></padding>
            <TextField fx:id="txtSearch" promptText="Search workers..." styleClass="search-field"/>
            <FontIcon iconLiteral="fth-search" iconSize="14" styleClass="search-icon"/>
        </HBox>
        <ComboBox fx:id="cmbStatus" promptText="All Status" styleClass="filter-combo"/>
    </FlowPane>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="All Workers" styleClass="card-title"/>
        <CharmListView fx:id="workerList" VBox.vgrow="ALWAYS"/>
    </VBox>
</VBox>