<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="smartfarm.ui.TaskController"
      spacing="16" styleClass="content-pane" prefWidth="1200" prefHeight="900">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Task Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddTask" text="+ Add Task" styleClass="btn-primary" onAction="#onAddTask"/>
    </HBox>

    <HBox spacing="16">
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#e8f5e9;-fx-background-radius:10;" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-check-square" iconSize="18" iconColor="#2e7d32"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total Tasks" style="-fx-font-size:12;-fx-text-fill:#6b7280;"/>
                    <Label fx:id="lblTotalTasks" text="0" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;"/>
                    <Label text="All assigned tasks" style="-fx-font-size:11;-fx-text-fill:#9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#fef3c7;-fx-background-radius:10;" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-clock" iconSize="18" iconColor="#d97706"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Pending" style="-fx-font-size:12;-fx-text-fill:#6b7280;"/>
                    <Label fx:id="lblPending" text="0" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;"/>
                    <Label text="Awaiting action" style="-fx-font-size:11;-fx-text-fill:#9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#dbeafe;-fx-background-radius:10;" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-refresh-cw" iconSize="18" iconColor="#1d4ed8"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="In Progress" style="-fx-font-size:12;-fx-text-fill:#6b7280;"/>
                    <Label fx:id="lblInProgress" text="0" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;"/>
                    <Label text="Currently active" style="-fx-font-size:11;-fx-text-fill:#9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
        <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="6">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#d1fae5;-fx-background-radius:10;" prefWidth="42" prefHeight="42" alignment="CENTER">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="18" iconColor="#065f46"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Completed" style="-fx-font-size:12;-fx-text-fill:#6b7280;"/>
                    <Label fx:id="lblCompleted" text="0" style="-fx-font-size:24;-fx-font-weight:bold;-fx-text-fill:#111827;"/>
                    <Label text="Successfully done" style="-fx-font-size:11;-fx-text-fill:#9ca3af;"/>
                </VBox>
            </HBox>
        </VBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <HBox alignment="CENTER_LEFT" styleClass="search-box">
            <padding><Insets right="8" left="8"/></padding>
            <FontIcon iconLiteral="fth-search" iconSize="14" styleClass="search-icon"/>
            <TextField fx:id="txtSearch" promptText="Search tasks..." styleClass="search-field"/>
        </HBox>
        <ComboBox fx:id="cmbStatus" promptText="All Status" styleClass="filter-combo"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
        <Label text="All Tasks" styleClass="card-title"/>
        <TableView fx:id="taskTable" VBox.vgrow="ALWAYS" prefHeight="400">
            <columns>
                <TableColumn fx:id="colTask"       text="Task"        prefWidth="200"/>
                <TableColumn fx:id="colAssignedTo" text="Assigned To" prefWidth="130"/>
                <TableColumn fx:id="colPlot"       text="Plot"        prefWidth="100"/>
                <TableColumn fx:id="colDueDate"    text="Due Date"    prefWidth="120"/>
                <TableColumn fx:id="colPriority"   text="Priority"    prefWidth="90"/>
                <TableColumn fx:id="colStatus"     text="Status"      prefWidth="100"/>
                <TableColumn fx:id="colActions"    text="Actions"     prefWidth="140"/>
            </columns>
        </TableView>
    </VBox>
</VBox>