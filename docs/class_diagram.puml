@startuml Agrilliant Class Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 11
skinparam nodesep 60
skinparam ranksep 45

title Agrilliant — Smart Farm Management System\nClass Diagram

' ════════════════════════════════════════
'  MODEL LAYER
' ════════════════════════════════════════
package "model" #E8F5E9 {

    class User {
        - id : int
        - username : String
        - email : String
        - fullName : String
        - role : Role
        + getId() : int
        + getUsername() : String
        + getEmail() : String
        + getFullName() : String
        + getRole() : Role
    }

    enum "User.Role" as UserRole {
        ADMIN
        MANAGER
        WORKER
    }

    class Admin {
        - adminId : int
        - fullName : String
        - username : String
        - email : String
        - passwordHash : String
        - phone : String
        - active : boolean
        - createdAt : LocalDateTime
        - updatedAt : LocalDateTime
        + isActive() : boolean
    }

    class Manager {
        - managerId : int
        - fullName : String
        - username : String
        - email : String
        - passwordHash : String
        - phone : String
        - active : boolean
        - createdAt : LocalDateTime
        - updatedAt : LocalDateTime
        + isActive() : boolean
    }

    class Worker {
        - workerId : int
        - fullName : String
        - phone : String
        - email : String
        - passwordHash : String
        - jobTitle : String
        - skills : String
        - onDuty : boolean
        - fingerprintId : Integer
        - managerId : int
        - createdAt : LocalDateTime
        - updatedAt : LocalDateTime
        + getActiveTaskCount(List<Task>) : int
        + isAvailable(List<Task>) : boolean
    }

    class Plot {
        - plotId : int
        - name : String
        - location : String
        - sizeAcres : double
        - soilType : String
        - managerId : int
        - irrigationType : String
        - status : String
        - createdAt : LocalDateTime
        - updatedAt : LocalDateTime
    }

    class Crop {
        - cropId : int
        - cropName : String
        - plantingDate : LocalDate
        - harvestDate : LocalDate
        - growthStage : GrowthStage
        - plotId : int
        - expectedYield : double
        + advanceStage() : void
        + isOverdue() : boolean
    }

    enum "Crop.GrowthStage" as GrowthStage {
        PLANTED
        GROWING
        READY
        HARVESTED
    }

    class Device {
        - deviceId : int
        - deviceCode : String
        - type : Type
        - status : Status
        - plotId : int
        - firmwareVersion : String
        - lastSeenAt : LocalDateTime
        - createdAt : LocalDateTime
    }

    enum "Device.Type" as DeviceType {
        TEMP_HUM
        SOIL
    }

    enum "Device.Status" as DeviceStatus {
        ONLINE
        OFFLINE
        MAINT
    }

    class SensorReading {
        - readingId : int
        - deviceId : int
        - temperature : float
        - humidity : float
        - soilMoisture : float
        - timestamp : LocalDateTime
        + getTemperature() : float
        + getHumidity() : float
        + getSoilMoisture() : float
    }

    class Alert {
        - alertId : int
        - alertType : String
        - severity : Severity
        - message : String
        - resolved : boolean
        - timestamp : LocalDateTime
        - plotId : int
        + resolve() : void
        + isCritical() : boolean
        + isResolved() : boolean
    }

    enum "Alert.Severity" as Severity {
        INFO
        WARNING
        CRITICAL
    }

    class Task {
        - taskId : int
        - description : String
        - status : Status
        - dueDate : LocalDate
        - plotId : int
        - alertId : Integer
        - assignedByMgrId : int
        - alertType : String
        - workerIds : List<Integer>
        + addWorker(int) : void
        + removeWorker(int) : void
        + isOverdue() : boolean
        + advanceStatus() : void
        + revertStatus() : void
    }

    enum "Task.Status" as TaskStatus {
        PENDING
        IN_PROGRESS
        DONE
    }

    class HarvestRecord {
        - recordId : int
        - harvestDate : LocalDate
        - quantityKg : double
        - grade : Grade
        - cropId : int
    }

    enum "HarvestRecord.Grade" as Grade {
        A
        B
        C
    }

    class Attendance {
        - attendanceId : int
        - workerId : int
        - checkIn : LocalDateTime
        - checkOut : LocalDateTime
        - deviceCode : String
        + isCheckedOut() : boolean
    }

    class DiseaseDetection {
        - detectionId : int
        - plotId : int
        - cropId : int
        - imagePath : String
        - diseaseName : String
        - confidence : Confidence
        - recommendation : String
        - status : DetectionStatus
        - detectedByWorkerId : int
    }

    enum "DiseaseDetection.Confidence" as DetectionConfidence {
        HIGH
        MEDIUM
        LOW
    }

    enum "DiseaseDetection.Status" as DetectionStatus {
        PENDING
        CONFIRMED
        DISMISSED
    }

    class Notification {
        - notificationId : int
        - recipientId : int
        - recipientRole : RecipientRole
        - channel : Channel
        - subject : String
        - body : String
        - status : Status
        - relatedEntityType : String
        - relatedEntityId : Integer
    }

    enum "Notification.RecipientRole" as NotifRecipientRole {
        ADMIN
        MANAGER
        WORKER
    }

    enum "Notification.Channel" as NotifChannel {
        PUSH
        SMS
        WHATSAPP
        EMAIL
    }

    enum "Notification.Status" as NotifStatus {
        QUEUED
        SENT
        FAILED
    }

    class SystemLog {
        - timestamp : LocalDateTime
        - type : LogType
        - source : String
        - message : String
        - user : String
        + getFormattedTimestamp() : String
    }

    enum "SystemLog.LogType" as LogType {
        INFO
        WARNING
        ERROR
    }
}

' ════════════════════════════════════════
'  DAO LAYER
' ════════════════════════════════════════
package "dao" #E3F2FD {

    interface GenericDAO<T> {
        + save(T) : void
        + getById(int) : T
        + getAll() : List<T>
        + update(T) : void
        + delete(int) : void
    }

    class AdminDAO {
        + getByEmail(String) : Admin
        + getByUsername(String) : Admin
    }

    class ManagerDAO {
        + getByEmail(String) : Manager
        + getByUsername(String) : Manager
    }

    class WorkerDAO {
        + getByManager(int) : List<Worker>
        + getByPhoneOrEmail(String) : Worker
    }

    class PlotDAO

    class CropDAO {
        + updateGrowthStage(int, GrowthStage) : void
    }

    class DeviceDAO {
        + getByCode(String) : Device
    }

    class SensorDAO {
        + getRecent(int) : List<SensorReading>
        + getRecentForPlot(int, int) : List<SensorReading>
    }

    class AlertDAO {
        + getUnresolved() : List<Alert>
        + getAlertsByPlot(int) : List<Alert>
        + markResolved(int) : void
    }

    class TaskDAO
    class HarvestDAO
    class AttendanceDAO {
        + getWorkerIdByFingerprint(int) : int
        + getOpenSession(int) : Attendance
        + checkIn(Attendance) : void
        + checkOut(int) : void
    }
    class UserDAO

    GenericDAO <|.. AdminDAO
    GenericDAO <|.. ManagerDAO
    GenericDAO <|.. WorkerDAO
    GenericDAO <|.. PlotDAO
    GenericDAO <|.. CropDAO
    GenericDAO <|.. DeviceDAO
    GenericDAO <|.. SensorDAO
    GenericDAO <|.. AlertDAO
    GenericDAO <|.. TaskDAO
    GenericDAO <|.. HarvestDAO
    GenericDAO <|.. AttendanceDAO
}

' ════════════════════════════════════════
'  SERVICE LAYER
' ════════════════════════════════════════
package "service" #FFF3E0 {

    class AuthService {
        - adminDAO : AdminDAO
        - managerDAO : ManagerDAO
        + signIn(String, String) : User
        + signUp(String, String, String, String, String, Role) : User
        + restoreSession(String) : User
        + {static} hashPassword(String) : String
        + verifyPassword(String, String) : boolean
    }

    class SensorService {
        - sensorDAO : SensorDAO
        - alertService : AlertService
        - {static} DB_SAVE_INTERVAL_MS : long
        - lastSaveTime : ConcurrentHashMap
        + processReading(SensorReading, String) : void
        + getRecentReadings(int) : List<SensorReading>
    }

    class AlertService {
        - alertDAO : AlertDAO
        - taskService : TaskService
        + checkAndAlert(SensorReading, int) : void
        + createAlertWithTask(String, Severity, String, int) : void
        + createAlertOnly(String, Severity, String, int) : void
        + resolveAlert(int) : void
        + getAllAlerts() : List<Alert>
        + getUnresolvedAlerts() : List<Alert>
        + getCriticalAlerts() : List<Alert>
    }

    class LiveSensorData <<Singleton>> {
        - {static} INSTANCE : LiveSensorData
        - temperature : SimpleFloatProperty
        - humidity : SimpleFloatProperty
        - soilMoisture : SimpleFloatProperty
        - deviceId : SimpleStringProperty
        - activeSensors : SimpleIntegerProperty
        + {static} getInstance() : LiveSensorData
        + update(SensorReading, String) : void
        + removeDevice(String) : void
        + temperatureProperty() : SimpleFloatProperty
        + humidityProperty() : SimpleFloatProperty
        + soilMoistureProperty() : SimpleFloatProperty
    }

    class SessionManager {
        + {static} saveSession(String) : void
        + {static} loadSession() : String
        + {static} clearSession() : void
    }

    class FingerprintService {
        - port : SerialPort
        - connected : boolean
        + connect(String) : boolean
        + enroll(int, EnrollCallback) : boolean
        + scan(EnrollCallback) : int
        + deleteTemplate(int) : boolean
        + disconnect() : void
    }

    interface "FingerprintService.EnrollCallback" as EnrollCallback {
        + onStatus(String) : void
    }

    class AttendanceService {
        - attendanceDAO : AttendanceDAO
        + handleFingerprintScan(int, String) : String
        + getAllRecords() : List<Attendance>
    }

    class PlantIdService <<Singleton>> {
        - {static} instance : PlantIdService
        - httpClient : HttpClient
        - apiKey : String
        + {static} getInstance() : PlantIdService
        + isAvailable() : boolean
        + analyzeImage(String) : CropHealthResult
    }

    class "PlantIdService.DiseaseSuggestion" as DiseaseSuggestion {
        + name : String
        + scientificName : String
        + probability : double
        + description : String
        + severity : String
        + treatment : String
    }

    class "PlantIdService.CropHealthResult" as CropHealthResult {
        + isPlant : boolean
        + isHealthy : boolean
        + cropName : String
        + diseases : List<DiseaseSuggestion>
        + getTopDisease() : DiseaseSuggestion
        + toDiseaseDetection(int, int, String, int) : DiseaseDetection
    }

    class SettingsManager <<Singleton>> {
        - {static} INSTANCE : SettingsManager
        - useFahrenheit : BooleanProperty
        + {static} getInstance() : SettingsManager
        + isUseFahrenheit() : boolean
        + setUseFahrenheit(boolean) : void
        + formatTemp(float) : String
        + formatTempShort(float) : String
    }

    class SystemLogManager <<Singleton>> {
        - {static} INSTANCE : SystemLogManager
        - logs : List<SystemLog>
        + {static} getInstance() : SystemLogManager
        + info(String, String, String) : void
        + warning(String, String, String) : void
        + error(String, String, String) : void
        + getLogs() : List<SystemLog>
    }

    class CropService
    class HarvestService
    class TaskService {
        + autoCreateTask(Task) : void
    }
    class WorkerService
}

' ════════════════════════════════════════
'  SERVER LAYER
' ════════════════════════════════════════
package "server" #FCE4EC {

    class FarmServer {
        - {static} PORT : int = 8080
        + start() : void
    }

    class SensorHandler implements Runnable {
        - socket : Socket
        - sensorService : SensorService
        - attendanceService : AttendanceService
        - deviceDAO : DeviceDAO
        - lastDeviceCode : String
        + run() : void
        - parseLine(String) : Parsed
        - resolveDeviceId(String) : int
        - handleFingerprint(String) : void
    }

    class MqttBridge <<Singleton>> {
        - {static} instance : MqttBridge
        - client : MqttAsyncClient
        - topicPrefix : String
        - connected : boolean
        + {static} getInstance() : MqttBridge
        + connect() : void
        + publishReading(String, float, float, float) : void
        + disconnect() : void
        + isConnected() : boolean
    }

    class "MqttBridge.SensorPayload" as SensorPayload {
        + deviceCode : String
        + temperature : float
        + humidity : float
        + soilMoisture : float
        + timestamp : long
    }

    class MqttSensorSubscriber <<Singleton>> {
        - {static} instance : MqttSensorSubscriber
        - client : MqttAsyncClient
        - connected : boolean
        + {static} getInstance() : MqttSensorSubscriber
        + start() : void
        + stop() : void
        + isConnected() : boolean
    }

    class NotificationService <<Singleton>> {
        - {static} instance : NotificationService
        - alertDAO : AlertDAO
        - liveSensorData : LiveSensorData
        + {static} getInstance() : NotificationService
        + sendNotification(NotificationType, String, String, String) : void
        + sendSensorAlert(String, String, double, double, Severity) : void
        + sendDeviceStatusNotification(String, String, String) : void
        + sendTaskNotification(String, String, String) : void
        + sendHarvestNotification(String, double, String) : void
        + addListener(NotificationListener) : void
        + removeListener(NotificationListener) : void
        + shutdown() : void
    }

    enum "NotificationService.NotificationType" as NotificationType {
        INFO
        WARNING
        CRITICAL
        SUCCESS
        TASK
        SYSTEM
    }

    interface "NotificationService.NotificationListener" as NotificationListener {
        + onNotification(Notification) : void
    }
}

' ════════════════════════════════════════
'  UI LAYER
' ════════════════════════════════════════
package "ui" #F3E5F5 {

    class LoginPage {
        - authService : AuthService
        - fpService : FingerprintService
        - workerDAO : WorkerDAO
        + createView() : Parent
        - buildLeftPanel() : StackPane
        - buildRightPanel() : VBox
        - handleSignIn() : void
        - handleSignUp() : void
        - handleFingerprintLogin() : void
        - switchToSignIn() : void
        - switchToSignUp() : void
    }

    class DashboardController {
        - currentUser : User
        - pageContainer : StackPane
        - alertDAO : AlertDAO
        - taskDAO : TaskDAO
        - cropDAO : CropDAO
        - plotDAO : PlotDAO
        - workerDAO : WorkerDAO
        - harvestDAO : HarvestDAO
        - sensorDAO : SensorDAO
        + setCurrentUser(User) : void
        - subscribeLiveSensor() : void
        - updateTemperature(float) : void
        - updateHumidity(float) : void
        - updateSoilMoisture(float) : void
        - onLogout() : void
    }

    class SignInController {
        - authService : AuthService
        - onSignIn() : void
        - navigateToDashboard(User) : void
    }

    class SignUpController {
        - authService : AuthService
        - onSignUp() : void
    }

    class PlotController {
        - plotDAO : PlotDAO
        - cropDAO : CropDAO
        + populatePlotDetail(Plot) : void
    }

    class CropController {
        - cropDAO : CropDAO
        - plotDAO : PlotDAO
        + showCropDetail(Crop) : void
        + populateDetail(Crop) : void
    }

    class MonitoringController {
        - sensorService : SensorService
        - plotDAO : PlotDAO
        - subscribeLiveSensor() : void
    }

    class HarvestController {
        - harvestDAO : HarvestDAO
        - cropDAO : CropDAO
        + reconcileHarvestedCrops() : void
    }

    class TaskController {
        - taskDAO : TaskDAO
        - workerDAO : WorkerDAO
        - plotDAO : PlotDAO
    }

    class WorkerController {
        - workerService : WorkerService
        - workerDAO : WorkerDAO
        - taskDAO : TaskDAO
        - fpService : FingerprintService
    }

    class UsersController {
        - adminDAO : AdminDAO
        - managerDAO : ManagerDAO
        - workerDAO : WorkerDAO
    }

    class AlertController {
        - alertService : AlertService
        - sensorDAO : SensorDAO
        - taskDAO : TaskDAO
    }

    class ReportsController {
        - harvestDAO : HarvestDAO
        - cropDAO : CropDAO
    }

    class LogsController {
        - logManager : SystemLogManager
    }

    class DiseaseDetectionPage extends javafx.scene.layout.VBox {
        - plantIdService : PlantIdService
        + analyzeImage(File) : void
    }

    class AttendancePage extends javafx.scene.layout.VBox {
        - attendanceService : AttendanceService
        - workerDAO : WorkerDAO
    }

    class SettingsPage extends javafx.scene.layout.VBox {
        - txtServerIp : TextField
        - txtServerPort : TextField
        - spnReadInterval : Spinner
    }

    class AboutPage extends javafx.scene.layout.VBox {
    }

    class CropsPage extends javafx.scene.layout.VBox {
        - table : TableView
        - data : ObservableList
        - showAddDialog() : void
    }
}

' ════════════════════════════════════════
'  UTIL LAYER
' ════════════════════════════════════════
package "util" #ECEFF1 {

    class DBConnection {
        - {static} connection : Connection
        + {static} getInstance() : Connection
    }

    class ThresholdConfig {
        + {static} TEMP_CRITICAL_HIGH : float = 35.0
        + {static} TEMP_WARNING_HIGH : float = 30.0
        + {static} TEMP_CRITICAL_LOW : float = 5.0
        + {static} HUM_WARNING_LOW : float = 30.0
        + {static} HUM_WARNING_HIGH : float = 85.0
        + {static} SOIL_CRITICAL_DRY : float = 20.0
        + {static} SOIL_WARNING_DRY : float = 30.0
        + {static} SOIL_WARNING_WET : float = 85.0
    }

    class CSVExporter {
        + {static} exportSensorData(List<SensorReading>) : String
    }

    class Logger {
        + {static} logger(Runnable) : void
    }
}

' ════════════════════════════════════════
'  APPLICATION ENTRY
' ════════════════════════════════════════
class Main extends javafx.application.Application {
    + start(Stage) : void
    + {static} main(String[]) : void
}

class Launcher {
    + {static} main(String[]) : void
}

' ════════════════════════════════════════
'  RELATIONSHIPS
' ════════════════════════════════════════

' Model enums
User *-- UserRole
Crop *-- GrowthStage
Device *-- DeviceType
Device *-- DeviceStatus
Alert *-- Severity
Task *-- TaskStatus
HarvestRecord *-- Grade
SystemLog *-- LogType
DiseaseDetection *-- DetectionConfidence
DiseaseDetection *-- DetectionStatus
Notification *-- NotifRecipientRole
Notification *-- NotifChannel
Notification *-- NotifStatus

' Model associations
Manager "1" --> "*" Worker : manages
Manager "1" --> "*" Plot : oversees
Plot "1" --> "*" Crop : contains
Plot "1" --> "*" Device : has
Device "1" --> "*" SensorReading : produces
Plot "1" --> "*" Alert : generates
Alert "0..1" --> "*" Task : triggers
Task "*" --> "*" Worker : assigned to
Crop "1" --> "*" HarvestRecord : yields
Crop "1" --> "*" DiseaseDetection : detected on
Worker "1" --> "*" Attendance : checks in

' DAO uses model
AdminDAO --> Admin
ManagerDAO --> Manager
WorkerDAO --> Worker
PlotDAO --> Plot
CropDAO --> Crop
DeviceDAO --> Device
SensorDAO --> SensorReading
AlertDAO --> Alert
TaskDAO --> Task
HarvestDAO --> HarvestRecord
AttendanceDAO --> Attendance

' DAO uses DBConnection
GenericDAO ..> DBConnection : <<uses>>

' Service uses DAO
AuthService --> AdminDAO
AuthService --> ManagerDAO
SensorService --> SensorDAO
SensorService --> AlertService
SensorService --> LiveSensorData
SensorService --> MqttBridge : publishes
AlertService --> AlertDAO
AlertService --> TaskService
AlertService ..> ThresholdConfig : <<uses>>
AttendanceService --> AttendanceDAO
FingerprintService --> EnrollCallback
PlantIdService --> DiseaseSuggestion
PlantIdService --> CropHealthResult
CropHealthResult ..> DiseaseDetection : converts to

' Server
FarmServer --> SensorHandler : creates
SensorHandler --> SensorService
SensorHandler --> AttendanceService
SensorHandler --> DeviceDAO
SensorHandler --> LiveSensorData : updates
MqttBridge --> SensorPayload
MqttSensorSubscriber --> LiveSensorData : updates
MqttSensorSubscriber ..> SensorPayload : deserializes
NotificationService --> AlertDAO
NotificationService --> LiveSensorData
NotificationService *-- NotificationType
NotificationService --> NotificationListener

' UI dependencies
Launcher --> Main : launches
Main --> FarmServer : starts
Main --> MqttBridge : connects
Main --> MqttSensorSubscriber : starts
Main --> AuthService : restores session
Main --> SessionManager
Main --> LoginPage : shows on start
Main --> DashboardController : on restored session

LoginPage --> AuthService
LoginPage --> FingerprintService
LoginPage --> WorkerDAO
LoginPage --> SessionManager

SignInController --> AuthService
SignInController --> SessionManager
SignInController --> DashboardController

DashboardController --> LiveSensorData : subscribes
DashboardController --> LoginPage : logout navigates to
DashboardController --> SettingsPage : navigates
DashboardController --> AboutPage : navigates
DashboardController --> CropsPage : navigates
DashboardController --> DiseaseDetectionPage : navigates
DashboardController --> AttendancePage : navigates
DashboardController --> SettingsManager

PlotController --> PlotDAO
PlotController --> CropDAO

CropController --> CropDAO
CropController --> PlotDAO
CropController --> LiveSensorData

MonitoringController --> SensorService
MonitoringController --> PlotDAO
MonitoringController --> LiveSensorData : subscribes

HarvestController --> HarvestDAO
HarvestController --> CropDAO

TaskController --> TaskDAO
TaskController --> WorkerDAO
TaskController --> PlotDAO

WorkerController --> WorkerService
WorkerController --> WorkerDAO
WorkerController --> TaskDAO
WorkerController --> FingerprintService

UsersController --> AdminDAO
UsersController --> ManagerDAO
UsersController --> WorkerDAO

AlertController --> AlertService
AlertController --> SensorDAO
AlertController --> TaskDAO

ReportsController --> HarvestDAO
ReportsController --> CropDAO

LogsController --> SystemLogManager

DiseaseDetectionPage --> PlantIdService

AttendancePage --> AttendanceService
AttendancePage --> WorkerDAO

@enduml
